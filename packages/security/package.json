{
  "name": "@tryghost/security",
  "version": "3.0.0",
  "description": "Security primitives for token generation, password hashing, and safe identifiers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/framework.git",
    "directory": "packages/security"
  },
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build": "tsc",
    "prepare": "tsc",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest run --config ../../vitest.config.ts",
    "test": "yarn test:types && yarn test:unit",
    "lint:code": "eslint src/ --ext .ts --cache",
    "lint": "yarn lint:code && yarn lint:test",
    "lint:test": "eslint -c test/.eslintrc.cjs test/ --ext .ts --cache"
  },
  "files": [
    "build"
  ],
  "devDependencies": {
    "sinon": "21.0.1",
    "typescript": "5.9.3",
    "uuid": "13.0.0"
  },
  "dependencies": {
    "@tryghost/string": "0.3.1",
    "bcryptjs": "3.0.3"
  }
}

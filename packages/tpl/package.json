{
  "name": "@tryghost/tpl",
  "version": "2.2.3",
  "license": "MIT",
  "author": "Ghost Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TryGhost/framework.git",
    "directory": "packages/tpl"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib/*.js",
    "lib/*.d.ts"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch --preserveWatchOutput --sourceMap",
    "build": "tsc",
    "prepare": "tsc",
    "pretest": "pnpm run build",
    "test": "pnpm run test:types && NODE_ENV=testing vitest run --coverage",
    "test:types": "tsc -p tsconfig.test.json --noEmit",
    "lint": "oxlint -c ../../.oxlintrc.json .",
    "posttest": "pnpm run lint"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "24.13.1",
    "typescript": "catalog:"
  }
}

  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.12.4",
    "@types/sinon": "21.0.1",
    "@types/stoppable": "1.1.3",
    "@types/supertest": "7.2.0",
    "knex": "3.2.10",

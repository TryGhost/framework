  "license": "MIT",
  "type": "module",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "echo \"Implement me!\"",
    "build": "tsc",
    "prepare": "tsc",
    "test:types": "tsc --noEmit",
